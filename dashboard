<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Purohith Services</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .dashboard-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        
        .stat-card {
            background: linear-gradient(135deg, #8B4513, #5a2d0c);
            color: white;
            padding: 25px;
            border-radius: 20px;
            text-align: center;
        }
        
        .stat-card i {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }
        
        .stat-card h3 {
            font-size: 2rem;
            margin: 10px 0;
        }
        
        .bookings-table-container {
            background: white;
            border-radius: 20px;
            padding: 20px;
            overflow-x: auto;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        }
        
        .bookings-table {
            width: 100%;
            border-collapse: collapse;
        }
        
        .bookings-table th {
            background: #8B4513;
            color: white;
            padding: 15px;
            text-align: left;
        }
        
        .bookings-table td {
            padding: 12px 15px;
            border-bottom: 1px solid #eee;
        }
        
        .bookings-table tr:hover {
            background: #fff5ed;
        }
        
        .status-pending {
            background: #ff9800;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            display: inline-block;
        }
        
        .status-confirmed {
            background: #4caf50;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            display: inline-block;
        }
        
        .action-buttons button {
            margin: 0 5px;
            padding: 5px 10px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-confirm {
            background: #4caf50;
            color: white;
        }
        
        .btn-delete {
            background: #f44336;
            color: white;
        }
        
        .btn-whatsapp {
            background: #25D366;
            color: white;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px;
            color: #999;
        }
        
        .empty-state i {
            font-size: 4rem;
            margin-bottom: 20px;
        }
        
        .filter-section {
            margin-bottom: 20px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .filter-section input, .filter-section select {
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 10px;
            font-family: inherit;
        }
        
        .export-btn {
            background: #8B4513;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            cursor: pointer;
            margin-left: auto;
        }
        
        @media (max-width: 768px) {
            .bookings-table {
                font-size: 12px;
            }
            
            .bookings-table th, .bookings-table td {
                padding: 8px;
            }
        }
    </style>
</head>
<body>
    <nav>
        <div class="container">
            <div class="nav-content">
                <div class="logo">
                    <i class="fas fa-om"></i>
                    <h2>Purohith Services</h2>
                </div>
                <ul class="nav-links">
                    <li><a href="index.html">Home</a></li>
                    <li><a href="services.html">Services</a></li>
                    <li><a href="rituals.html">Rituals</a></li>
                    <li><a href="booking.html">Book Now</a></li>
                    <li><a href="dashboard.html">Dashboard</a></li>
                    <li><a href="contact.html">Contact</a></li>
                </ul>
                <div class="mobile-menu">☰</div>
            </div>
        </div>
    </nav>

    <section class="page-header">
        <div class="container">
            <h1><i class="fas fa-chart-line"></i> Booking Dashboard</h1>
            <p>Manage and view all your ritual bookings</p>
        </div>
    </section>

    <section class="dashboard-section" style="padding: 60px 0;">
        <div class="container">
            <div class="dashboard-stats" id="stats">
                <div class="stat-card">
                    <i class="fas fa-calendar-check"></i>
                    <h3 id="totalBookings">0</h3>
                    <p>Total Bookings</p>
                </div>
                <div class="stat-card">
                    <i class="fas fa-clock"></i>
                    <h3 id="pendingBookings">0</h3>
                    <p>Pending</p>
                </div>
                <div class="stat-card">
                    <i class="fas fa-check-circle"></i>
                    <h3 id="confirmedBookings">0</h3>
                    <p>Confirmed</p>
                </div>
                <div class="stat-card">
                    <i class="fas fa-users"></i>
                    <h3 id="uniqueClients">0</h3>
                    <p>Unique Clients</p>
                </div>
            </div>
            
            <div class="filter-section">
                <input type="text" id="searchInput" placeholder="🔍 Search by name or phone..." style="flex: 1;">
                <select id="statusFilter">
                    <option value="all">All Status</option>
                    <option value="pending">Pending</option>
                    <option value="confirmed">Confirmed</option>
                </select>
                <select id="ritualFilter">
                    <option value="all">All Rituals</option>
                </select>
                <button class="export-btn" onclick="exportToExcel()">
                    <i class="fas fa-download"></i> Export to Excel
                </button>
            </div>
            
            <div class="bookings-table-container">
                <div id="bookingsList"></div>
            </div>
        </div>
    </section>

    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>Purohith Services</h3>
                    <p>Preserving traditions through authentic Vedic rituals</p>
                </div>
                <div class="footer-section">
                    <h4>Quick Links</h4>
                    <a href="index.html">Home</a>
                    <a href="services.html">Services</a>
                    <a href="booking.html">Booking</a>
                    <a href="dashboard.html">Dashboard</a>
                    <a href="contact.html">Contact</a>
                </div>
                <div class="footer-section">
                    <h4>Contact</h4>
                    <p><i class="fas fa-phone"></i> +91 83280 59590</p>
                    <p><i class="fas fa-phone"></i> +91 94401 75900</p>
                    <p><i class="fas fa-envelope"></i> aryanvaruna@gmail.com</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 Purohith Services. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="script.js"></script>
    <script>
        // Load and display bookings
        function loadBookings() {
            let bookings = JSON.parse(localStorage.getItem('purohithBookings')) || [];
            
            // Update stats
            document.getElementById('totalBookings').textContent = bookings.length;
            document.getElementById('pendingBookings').textContent = bookings.filter(b => b.status === 'pending').length;
            document.getElementById('confirmedBookings').textContent = bookings.filter(b => b.status === 'confirmed').length;
            
            // Unique clients
            const uniquePhones = new Set(bookings.map(b => b.phone));
            document.getElementById('uniqueClients').textContent = uniquePhones.size;
            
            // Populate ritual filter
            const rituals = [...new Set(bookings.map(b => b.ritual))];
            const ritualFilter = document.getElementById('ritualFilter');
            ritualFilter.innerHTML = '<option value="all">All Rituals</option>';
            rituals.forEach(ritual => {
                ritualFilter.innerHTML += `<option value="${ritual}">${ritual}</option>`;
            });
            
            // Apply filters
            applyFilters();
        }
        
        function applyFilters() {
            let bookings = JSON.parse(localStorage.getItem('purohithBookings')) || [];
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const statusFilter = document.getElementById('statusFilter').value;
            const ritualFilter = document.getElementById('ritualFilter').value;
            
            let filtered = bookings.filter(booking => {
                const matchesSearch = booking.name.toLowerCase().includes(searchTerm) || 
                                     booking.phone.includes(searchTerm);
                const matchesStatus = statusFilter === 'all' || booking.status === statusFilter;
                const matchesRitual = ritualFilter === 'all' || booking.ritual === ritualFilter;
                return matchesSearch && matchesStatus && matchesRitual;
            });
            
            displayBookings(filtered);
        }
        
        function displayBookings(bookings) {
            const container = document.getElementById('bookingsList');
            
            if (bookings.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="fas fa-inbox"></i>
                        <h3>No Bookings Found</h3>
                        <p>When clients book rituals, they will appear here.</p>
                        <a href="booking.html" class="btn-primary" style="margin-top: 20px; display: inline-block;">+ New Booking</a>
                    </div>
                `;
                return;
            }
            
            let html = `
                <table class="bookings-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Date</th>
                            <th>Name</th>
                            <th>Phone</th>
                            <th>Ritual</th>
                            <th>Event Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
            `;
            
            bookings.forEach((booking, index) => {
                const bookingDate = new Date(booking.createdAt).toLocaleDateString('en-IN');
                html += `
                    <tr>
                        <td>#${index + 1}</td>
                        <td>${bookingDate}</td>
                        <td><strong>${booking.name}</strong></td>
                        <td>${booking.phone}</td>
                        <td>${booking.ritual}</td>
                        <td>${booking.eventDate}</td>
                        <td>
                            <span class="status-${booking.status}">${booking.status === 'pending' ? '⏳ Pending' : '✅ Confirmed'}</span>
                        </td>
                        <td class="action-buttons">
                            ${booking.status === 'pending' ? `<button class="btn-confirm" onclick="confirmBooking('${booking.id}')"><i class="fas fa-check"></i></button>` : ''}
                            <button class="btn-whatsapp" onclick="sendWhatsApp('${booking.phone}', '${booking.name}', '${booking.ritual}')"><i class="fab fa-whatsapp"></i></button>
                            <button class="btn-delete" onclick="deleteBooking('${booking.id}')"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                `;
            });
            
            html += `</tbody></table>`;
            container.innerHTML = html;
        }
        
        function confirmBooking(id) {
            let bookings = JSON.parse(localStorage.getItem('purohithBookings')) || [];
            const index = bookings.findIndex(b => b.id === id);
            if (index !== -1) {
                bookings[index].status = 'confirmed';
                localStorage.setItem('purohithBookings', JSON.stringify(bookings));
                loadBookings();
                showAlert('Booking confirmed successfully!', 'success');
            }
        }
        
        function deleteBooking(id) {
            if (confirm('Are you sure you want to delete this booking?')) {
                let bookings = JSON.parse(localStorage.getItem('purohithBookings')) || [];
                bookings = bookings.filter(b => b.id !== id);
                localStorage.setItem('purohithBookings', JSON.stringify(bookings));
                loadBookings();
                showAlert('Booking deleted successfully!', 'success');
            }
        }
        
        function sendWhatsApp(phone, name, ritual) {
            const message = `Hello ${name},%0A%0AThank you for booking ${ritual} with Purohith Services.%0A%0AWe will contact you shortly to confirm the details.%0A%0A🙏 Namaste!`;
            window.open(`https://wa.me/${phone}?text=${message}`, '_blank');
        }
        
        function exportToExcel() {
            let bookings = JSON.parse(localStorage.getItem('purohithBookings')) || [];
            if (bookings.length === 0) {
                showAlert('No bookings to export!', 'error');
                return;
            }
            
            let csv = 'ID,Date,Name,Phone,Email,Ritual,Event Date,Event Time,Address,Status,Details\n';
            bookings.forEach((booking, index) => {
                csv += `${index + 1},${new Date(booking.createdAt).toLocaleDateString()},${booking.name},${booking.phone},${booking.email || ''},${booking.ritual},${booking.eventDate},${booking.eventTime || ''},${booking.address.replace(/,/g, ' ')},${booking.status},${booking.details || ''}\n`;
            });
            
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `purohith-bookings-${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
            URL.revokeObjectURL(url);
            showAlert('Export complete!', 'success');
        }
        
        // Event listeners
        document.getElementById('searchInput')?.addEventListener('input', applyFilters);
        document.getElementById('statusFilter')?.addEventListener('change', applyFilters);
        document.getElementById('ritualFilter')?.addEventListener('change', applyFilters);
        
        // Load bookings on page load
        loadBookings();
    </script>
</body>
</html>
